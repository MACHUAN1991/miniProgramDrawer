.user-section {
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.avatar.placeholder {
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-light);
}

.nickname {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.stats-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 40rpx 20rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.section {
  margin-bottom: 24rpx;
  padding: 0;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  padding: 30rpx 30rpx 20rpx;
}

.section-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.section-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.item-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.arrow {
  font-size: 36rpx;
  color: var(--text-light);
}

.frequency-options {
  display: flex;
  gap: 16rpx;
  padding: 0 30rpx 20rpx;
}

.freq-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
}

.freq-option.active {
  background: var(--primary-color);
  color: #fff;
}

.section-tip {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  padding: 0 30rpx 30rpx;
}

/* 主题管理弹窗 */
.picker-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  max-height: 60vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.close-btn {
  color: var(--primary-color);
  font-size: 28rpx;
}

.picker-list {
  max-height: 50vh;
}

.topic-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.topic-info {
  display: flex;
  align-items: center;
}

.topic-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.topic-count {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.delete-btn {
  color: #FF6B6B;
  font-size: 26rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: var(--text-light);
  font-size: 28rpx;
}

/* 退出按钮 */
.logout-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--text-light);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: var(--bg-color);
}

/* 登录弹窗 */
.login-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-dialog {
  width: 600rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 50rpx 40rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-avatar {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F4FD, #D4E9FC);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed var(--primary-color);
}

.avatar-placeholder .icon {
  font-size: 50rpx;
  margin-bottom: 8rpx;
}

.avatar-placeholder .hint {
  font-size: 20rpx;
  color: var(--primary-color);
}

.login-nickname {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  box-sizing: border-box;
}

.nickname-placeholder {
  color: var(--text-light);
}

.login-btns {
  display: flex;
  gap: 24rpx;
}

.login-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
}

.login-btn.cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.login-btn.confirm {
  background: var(--primary-color);
  color: #fff;
}