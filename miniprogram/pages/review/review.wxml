<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <text class="back-btn" bindtap="goBack">‹ 返回</text>
    <text class="title">回顾</text>
    <text class="progress">{{currentIndex + 1}} / {{clips.length}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{clips.length === 0}}" class="empty-state">
    <text>暂无内容可回顾</text>
  </view>

  <!-- 回顾卡片 -->
  <view wx:else class="review-card card">
    <view class="clip-type" style="background: {{clips[currentIndex].type === 'text' ? '#4A90D9' : '#FF6B6B'}}">
      {{clips[currentIndex].type === 'text' ? '文字' : '图片'}}
    </view>
    <text class="clip-date">{{clips[currentIndex].createdAt}}</text>

    <!-- 文字内容 -->
    <view wx:if="{{clips[currentIndex].type === 'text'}}" class="clip-content" bindtap="toggleExpand">
      <text>{{clips[currentIndex].content}}</text>
    </view>

    <!-- 图片内容 -->
    <view wx:elif="{{clips[currentIndex].type === 'image'}}" class="clip-content image-content">
      <image
        class="review-image"
        src="{{clips[currentIndex].imageUrl}}"
        mode="aspectFit"
        bindtap="previewImage"
        data-url="{{clips[currentIndex].imageUrl}}"
      />
      <text wx:if="{{clips[currentIndex].content}}" class="image-desc">{{clips[currentIndex].content}}</text>
    </view>
  </view>

  <!-- 导航按钮 -->
  <view class="nav-btns">
    <view class="nav-btn {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="prevClip">‹ 上一条</view>
    <view class="nav-btn {{currentIndex >= clips.length - 1 ? 'disabled' : ''}}" bindtap="nextClip">下一条 ›</view>
  </view>
</view>