.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  background: #fff;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.back-btn {
  font-size: 32rpx;
  color: #4A90D9;
  padding: 0 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.progress {
  font-size: 28rpx;
  color: #999;
  padding: 0 20rpx;
}

.loading-state,
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

.review-card {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.clip-type {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.clip-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.clip-content {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.image-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.review-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.image-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  width: 100%;
}

.nav-btns {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: #4A90D9;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.nav-btn.disabled {
  background: #ccc;
  color: #fff;
}