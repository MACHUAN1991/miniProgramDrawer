<view class="container">
  <view class="top-bar">
    <view class="login-btn" bindtap="onLoginTap">
      <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="login-avatar" src="{{userInfo.avatarUrl}}" />
      <text wx:else class="login-icon">👤</text>
    </view>
    <view class="search-wrapper">
      <input
        class="search-input {{searchFocused ? 'focused' : ''}}"
        placeholder="搜索..."
        value="{{searchKey}}"
        bindinput="onSearch"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
      />
      <text wx:if="{{searchKey}}" class="search-clear" bindtap="clearSearch">×</text>
    </view>
    <view class="add-btn" bindtap="showAdd">+ 新增</view>
  </view>

  <!-- 分类筛选栏 -->
  <view class="topic-filter">
    <view
      class="topic-tag {{selectedType === '' ? 'active' : ''}}"
      bindtap="selectType"
      data-type=""
    >
      全部 {{countAll}}
    </view>
    <view
      class="topic-tag {{selectedType === 'text' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="text"
    >
      文字 {{countText}}
    </view>
    <view
      class="topic-tag {{selectedType === 'image' ? 'active' : ''}}"
      bindtap="selectType"
      data-type="image"
    >
      图片 {{countImage}}
    </view>
  </view>

  <!-- 每日推荐 -->
  <view wx:if="{{dailyRecommend && !loading && !searchKey}}" class="daily-recommend" bindtap="onRecommendTap">
    <view class="daily-header">
      <text class="daily-title">📌 今日推荐</text>
    </view>
    <view class="daily-content">
      <text wx:if="{{dailyRecommend.type === 'text'}}" class="daily-text">{{dailyRecommend.content}}</text>
      <image wx:else class="daily-image" src="{{dailyRecommend.imageUrl}}" mode="aspectFill" />
    </view>
    <view class="daily-footer">
      <text class="daily-meta">{{dailyRecommend.creatorShow}} · {{dailyRecommend.createdAt}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="spinner"></view>
    <text>加载中...</text>
  </view>

  <view class="clips-list" wx:else>
    <view wx:for="{{clips}}" wx:key="_id" class="clip-card {{deletingId === item._id ? 'deleting' : ''}}" wx:if="{{deletingId !== item._id}}">
      <view class="clip-header">
        <text class="clip-type">{{item.type === 'text' ? '文字' : '图片'}}</text>
        <view class="clip-meta">
          <image wx:if="{{item.creatorAvatar}}" class="creator-avatar" src="{{item.creatorAvatar}}" />
          <text>{{item.creatorShow}}</text>
          <text class="meta-dot">·</text>
          <text>{{item.createdAt}}</text>
        </view>
      </view>

      <view wx:if="{{item.type === 'text'}}" class="clip-content" bindtap="toggleExpand" data-index="{{index}}">
        <text class="{{item.expanded ? '' : 'text-ellipsis'}}" selectable="{{item.expanded}}">{{item.content}}</text>
        <text wx:if="{{item.content.length > 100}}" class="expand-btn">{{item.expanded ? '收起' : '展开'}}</text>
      </view>

      <view wx:else class="clip-content image-content">
        <image src="{{item.imageUrl}}" mode="widthFix" bindtap="previewImage" data-url="{{item.imageUrl}}" />
        <text wx:if="{{item.content}}" class="image-desc">{{item.content}}</text>
      </view>

      <view class="clip-actions">
        <text class="action-btn delete-btn" data-id="{{item._id}}" bindtap="deleteClip">删除</text>
      </view>
    </view>
  </view>

  <view wx:if="{{clips.length === 0}}" class="empty-state">
    <text>暂无收藏内容</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{loadingMore}}" class="loading-more">
    <view class="spinner-sm"></view>
    <text>加载中...</text>
  </view>
  <view wx:if="{{!hasMore && clips.length > 0}}" class="no-more">
    <text>没有更多了</text>
  </view>

  <!-- 返回顶部 -->
  <view wx:if="{{showBackTop}}" class="back-top" bindtap="backToTop">
    <text>↑</text>
  </view>
</view>

<!-- 新增弹窗 -->
<view wx:if="{{showDialog}}" class="dialog-mask">
  <view class="dialog">
    <view class="dialog-header">
      <text>新增</text>
      <text class="close-btn" bindtap="closeDialog">×</text>
    </view>
    <view class="dialog-creator">
      <image wx:if="{{userInfo.avatarUrl}}" class="creator-avatar" src="{{userInfo.avatarUrl}}" />
      <text wx:else class="creator-avatar-placeholder">👤</text>
      <text class="creator-name">{{userInfo.nickName}}</text>
    </view>
    <view class="dialog-body">
      <textarea
        class="content-input {{dialogContentFocused ? 'focused' : ''}}"
        placeholder="请输入文字内容"
        value="{{dialogContent}}"
        bindinput="onContentInput"
        bindfocus="onContentFocus"
        bindblur="onContentBlur"
        cursor-spacing="20"
      />
      <view class="image-upload" bindtap="chooseImage">
        <image wx:if="{{dialogImageUrl}}" src="{{dialogImageUrl}}" mode="aspectFit" />
        <text wx:else>+ 添加图片（可选）</text>
      </view>
    </view>
    <view class="dialog-footer">
      <button class="btn-cancel" bindtap="closeDialog">取消</button>
      <button class="btn-save" bindtap="saveClip">保存</button>
    </view>
  </view>
</view>

<!-- 密码弹窗 -->
<view wx:if="{{showPwd}}" class="pwd-mask">
  <view class="pwd-box">
    <view class="pwd-title">请输入密码</view>
    <input class="pwd-input {{pwdFocused ? 'focused' : ''}}" type="text" password value="{{pwdVal}}" bindinput="onPwdInput" bindfocus="onPwdFocus" bindblur="onPwdBlur" />
    <view class="pwd-btns">
      <text class="pwd-btn" bindtap="closePwd">取消</text>
      <text class="pwd-btn confirm" bindtap="submitPwd">确认</text>
    </view>
  </view>
</view>

<!-- 登录弹窗 -->
<view wx:if="{{showLogin}}" class="login-dialog-mask">
  <view class="login-dialog">
    <view class="login-dialog-header">设置头像和昵称</view>
    <view class="login-dialog-body">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{loginAvatar}}" class="avatar-img" src="{{loginAvatar}}" />
        <text wx:else class="avatar-placeholder">👤</text>
      </button>
      <input
        type="nickname"
        class="login-nickname {{loginNicknameFocused ? 'focused' : ''}}"
        placeholder="点击获取微信昵称"
        value="{{loginNickname}}"
        bindinput="onLoginNickname"
        bindblur="onLoginNickname"
        bindfocus="onLoginNicknameFocus"
      />
    </view>
    <view class="login-dialog-footer">
      <text class="login-btn cancel" bindtap="closeLogin">取消</text>
      <text class="login-btn confirm" bindtap="confirmLogin">确认</text>
    </view>
  </view>
</view>