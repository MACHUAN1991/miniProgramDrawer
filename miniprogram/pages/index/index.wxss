.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.top-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.topic-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.topic-tag {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #ddd;
  transition: all 0.2s;
}

.topic-tag.active {
  color: #fff;
  background: #4A90D9;
  border-color: #4A90D9;
}

.daily-recommend {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.daily-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.daily-title {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  opacity: 0.95;
}

.daily-content {
  margin-bottom: 16rpx;
}

.daily-text {
  color: #fff;
  font-size: 28rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.daily-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.daily-footer {
  display: flex;
  justify-content: flex-end;
}

.daily-meta {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}

.search-wrapper {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 32rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.search-input.focused {
  border-color: #4A90D9;
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.2);
}

.search-clear {
  position: absolute;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 36rpx;
  color: #999;
  background: #e0e0e0;
  border-radius: 50%;
  z-index: 1;
}

.action-btns {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.login-btn {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.login-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  object-fit: cover;
}

.login-icon {
  font-size: 32rpx;
}

.add-btn {
  background: #4A90D9;
  color: #fff;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.clips-list {
  padding-bottom: 40rpx;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.spinner-sm {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.back-top {
  position: fixed;
  right: 30rpx;
  bottom: 60rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(74, 144, 217, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 50;
}

.back-top text {
  color: #fff;
  font-size: 40rpx;
  line-height: 1;
}

.clip-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: opacity 0.3s, transform 0.3s;
}

.clip-card.deleting {
  opacity: 0;
  transform: translateX(100%);
}

.clip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.clip-type {
  background: #4A90D9;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.clip-meta {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
  flex-shrink: 0;
}

.clip-meta .creator-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}

.clip-meta .meta-dot {
  color: #888;
}

.clip-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  word-break: break-all;
}

.clip-content .text-ellipsis {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.expand-btn {
  color: #4A90D9;
  font-size: 24rpx;
  margin-top: 8rpx;
  display: inline-block;
}

.image-content image {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.image-desc {
  font-size: 26rpx;
  color: #666;
}

.clip-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.clip-actions text {
  font-size: 24rpx;
  color: #888;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  transition: color 0.2s, background 0.2s;
  min-height: 44rpx;
  min-width: 88rpx;
  box-sizing: border-box;
}
.clip-actions text:active {
  color: #FF6B6B;
  background: rgba(255, 107, 107, 0.1);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 弹窗 */
.dialog-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog {
  width: 90%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: dialogIn 0.25s ease-out;
}

@keyframes dialogIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.dialog-creator {
  display: flex;
  align-items: center;
  padding: 0 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-creator .creator-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dialog-creator .creator-avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.dialog-creator .creator-name {
  font-size: 26rpx;
  color: #333;
}

.dialog-creator .creator-time {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
}

.dialog-body {
  padding: 0 30rpx 30rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s, background 0.2s;
}
.content-input.focused {
  border-color: #4A90D9;
  background: #fff;
}

.image-upload {
  margin-top: 20rpx;
  height: 200rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 26rpx;
}

.image-upload image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.dialog-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
  gap: 20rpx;
}

.dialog-footer button {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #4A90D9;
  color: #fff;
}

/* 密码弹窗 */
.pwd-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pwd-box {
  width: 500rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  animation: dialogIn 0.25s ease-out;
}

.pwd-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}

.pwd-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  font-size: 40rpx;
  letter-spacing: 8rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s, background 0.2s;
}
.pwd-input.focused {
  border-color: #4A90D9;
  background: #fff;
}

.pwd-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.pwd-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.pwd-btn.confirm {
  background: #4A90D9;
  color: #fff;
}

/* 登录弹窗 */
.login-dialog-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-dialog {
  width: 560rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: dialogIn 0.25s ease-out;
}

.login-dialog-header {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.login-dialog-body {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.login-avatar-btn {
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}

.login-avatar-btn::after {
  border: none;
}

.login-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  object-fit: cover;
}

.login-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.login-nickname {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
  line-height: 88rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s, background 0.2s;
}
.login-nickname.focused {
  border-color: #4A90D9;
  background: #fff;
}

.login-dialog-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
  gap: 20rpx;
}

.login-btn.cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.login-btn.confirm {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #4A90D9;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
}