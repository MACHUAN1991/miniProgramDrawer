page {
  --primary-color: #4A90D9;
  --primary-light: #7AB3ED;
  --bg-color: #F8F9FA;
  --bg-card: #FFFFFF;
  --text-primary: #2C3E50;
  --text-secondary: #7F8C8D;
  --text-light: #BDC3C7;
  --border-color: #ECF0F1;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: var(--bg-color);
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 24rpx 60rpx;
  font-size: 28rpx;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: var(--radius-full);
  padding: 24rpx 60rpx;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 60rpx;
  color: var(--text-light);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}